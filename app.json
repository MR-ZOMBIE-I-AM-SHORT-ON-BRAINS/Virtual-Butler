{
  "expo": {
"name": "Virtual-Butler",
   "slug": "virtual-butler",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4f46e5"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSContactsUsageDescription": "e-Butler needs access to your contacts to track call interactions and provide insights.",
        "NSLocationWhenInUseUsageDescription": "e-Butler uses location to provide smart reminders when you leave common places.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "e-Butler uses location to provide smart reminders when you leave common places.",
        "NSMicrophoneUsageDescription": "e-Butler may use microphone for voice features in future updates."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4f46e5",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
"package": "com.virtualbutler.app",
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_CALL_LOG",
        "android.permission.WRITE_CALL_LOG",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.BATTERY_STATS",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.FOREGROUND_SERVICE"
      ],
      "intentFilters": [
        {
          "action": "android.intent.action.MAIN",
          "category": "android.intent.category.LAUNCHER"
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/favicon.png",
          "color": "#4f46e5",
          "sounds": [
            "./assets/sounds/alarm.wav"
          ]
        }
      ],
      "expo-location",
      "expo-contacts",
      "expo-background-fetch",
      "expo-task-manager",
      "expo-secure-store"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "Amar9893",
    "platforms": [
      "android",
      "ios",
      "web"
    ]
  }
}